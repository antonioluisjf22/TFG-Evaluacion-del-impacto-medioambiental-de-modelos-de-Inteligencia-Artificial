                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Estructura production_impact correcta', () => {",
                  "    const pi = pm.response.json().production_impact;",
                  "    pm.expect(pi).to.have.property('input');",
                  "    pm.expect(pi).to.have.property('emissions');",
                  "    pm.expect(pi).to.have.property('energy');",
                  "    pm.expect(pi).to.have.property('equivalencies');",
                  "});",
                  "pm.test('1M queries/día reflejado en input', () => {",
                  "    pm.expect(pm.response.json().production_impact.input.queries_per_day).to.equal(1000000);",
                  "});",
                  "pm.test('Emisiones anuales > 0', () => {",
                  "    pm.expect(pm.response.json().production_impact.emissions.tons_co2_annual).to.be.greaterThan(0);",
                  "});",
                  "pm.test('Equivalencias con árboles y vuelos', () => {",
                  "    const equiv = pm.response.json().production_impact.equivalencies;",
                  "    pm.expect(equiv.trees_needed).to.be.greaterThan(0);",
                  "    pm.expect(equiv.transatlantic_flights).to.be.greaterThan(0);",
                  "});",
                  "pm.collectionVariables.set('prod_1M_kg', pm.response.json().production_impact.emissions.kg_co2_annual);"
                ]
              }
            }
          ]
