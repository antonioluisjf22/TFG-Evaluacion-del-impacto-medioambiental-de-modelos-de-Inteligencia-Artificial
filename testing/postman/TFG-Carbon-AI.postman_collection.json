    {
      "name": "3. Comparativa de Modelos",
      "item": [
        {
          "name": "3.1 Comparar todos los modelos",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data_center_id\": \"{{data_center_id}}\",\n  \"device_id\": \"{{device_id}}\",\n  \"network_id\": \"{{network_id}}\",\n  \"user_country\": \"{{user_country}}\",\n  \"request_type\": \"{{request_type}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/compare",
              "host": ["{{base_url}}"],
              "path": ["api", "compare"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna 15 modelos', () => {",
                  "    pm.expect(pm.response.json().comparative_table.length).to.equal(15);",
                  "});",
                  "pm.test('Cada fila tiene environmental_label', () => {",
                  "    pm.response.json().comparative_table.slice(0,5).forEach(row => {",
                  "        pm.expect(row).to.have.property('environmental_label');",
                  "    });",
                  "});",
                  "pm.test('Phi-2 emite menos que GPT-4', () => {",
                  "    const rows = pm.response.json().comparative_table;",
                  "    const phi2 = rows.find(r => r.model_id === 'phi-2');",
                  "    const gpt4 = rows.find(r => r.model_id === 'gpt-4');",
                  "    if (phi2 && gpt4) pm.expect(phi2.emissions_gCO2).to.be.lessThan(gpt4.emissions_gCO2);",
                  "});",
                  "pm.test('Tabla tiene resumen best/worst', () => {",
                  "    const d = pm.response.json();",
                  "    pm.expect(d).to.have.property('summary');",
                  "    pm.expect(d.summary).to.have.property('best_option');",
                  "    pm.expect(d.summary).to.have.property('worst_option');",
                  "});"
                ]
              }
            }
          ]
        },
