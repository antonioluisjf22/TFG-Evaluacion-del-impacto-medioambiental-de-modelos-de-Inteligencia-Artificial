{
  "info": {
    "name": "TFG Carbon AI",
    "description": "Suite de pruebas de integración manual para los 6 endpoints REST de la calculadora de emisiones de CO₂ de modelos de IA. Complementa la suite automática de pytest (373 tests).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "item": [
    {
      "name": "1. Setup — Catálogos",
      "item": [
        {
          "name": "GET /api/options",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/options",
              "host": ["{{base_url}}"],
              "path": ["api", "options"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Contiene todos los catálogos', () => {",
                  "    const d = pm.response.json();",
                  "    ['models','data_centers','devices','networks','request_types','countries']",
                  "        .forEach(k => pm.expect(d).to.have.property(k));",
                  "});",
                  "pm.test('15 modelos exactos', () => pm.expect(pm.response.json().models.length).to.equal(15));",
                  "pm.test('71 datacenters exactos', () => pm.expect(pm.response.json().data_centers.length).to.equal(71));",
                  "pm.test('20 dispositivos exactos', () => pm.expect(pm.response.json().devices.length).to.equal(20));",
                  "pm.test('5 tipos de red exactos', () => pm.expect(pm.response.json().networks.length).to.equal(5));",
                  "pm.test('7 request_types exactos', () => pm.expect(pm.response.json().request_types.length).to.equal(7));",
                  "pm.test('Cada modelo tiene los campos requeridos', () => {",
                  "    pm.response.json().models.forEach(m => {",
                  "        pm.expect(m).to.have.property('model_id');",
                  "        pm.expect(m).to.have.property('model_name');",
                  "        pm.expect(m).to.have.property('num_parameters');",
                  "    });",
                  "});",
                  "pm.test('Todos los DCs tienen country_code', () => {",
                  "    pm.response.json().data_centers.forEach(dc => {",
                  "        pm.expect(dc).to.have.property('country_code');",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/map-data",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/map-data",
              "host": ["{{base_url}}"],
              "path": ["api", "map-data"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('data_centers con coordenadas', () => {",
                  "    const dcs = pm.response.json().data_centers;",
                  "    pm.expect(dcs.length).to.be.greaterThan(0);",
                  "    pm.expect(dcs[0]).to.have.property('latitude');",
                  "    pm.expect(dcs[0]).to.have.property('longitude');",
                  "});",
                  "pm.test('Países con intensidad de carbono', () => {",
                  "    const countries = pm.response.json().countries;",
                  "    pm.expect(countries.length).to.be.greaterThan(0);",
                  "    const withCI = countries.filter(c => c.carbon_intensity != null);",
                  "    pm.expect(withCI.length).to.be.greaterThan(0);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Cálculo Individual",
      "item": [
        {
          "name": "2.1 GPT-4 estándar",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model_id\": \"{{model_id}}\",\n  \"data_center_id\": \"{{data_center_id}}\",\n  \"device_id\": \"{{device_id}}\",\n  \"network_id\": \"{{network_id}}\",\n  \"user_country\": \"{{user_country}}\",\n  \"request_type\": \"{{request_type}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/calculate",
              "host": ["{{base_url}}"],
              "path": ["api", "calculate"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('emissions_gCO2.total > 0', () => pm.expect(pm.response.json().emissions_gCO2.total).to.be.greaterThan(0));",
                  "pm.test('Tiene todas las secciones', () => {",
                  "    const d = pm.response.json();",
                  "    ['emissions_gCO2','energy_Wh','metadata','breakdown_percentage','environmental_label','equivalencies']",
                  "        .forEach(k => pm.expect(d).to.have.property(k));",
                  "});",
                  "pm.test('breakdown_percentage suma ~100%', () => {",
                  "    const bp = pm.response.json().breakdown_percentage;",
                  "    const sum = bp.device + bp.network + bp.datacenter;",
                  "    pm.expect(Math.abs(sum - 100)).to.be.lessThan(0.5);",
                  "});",
                  "pm.test('Etiqueta ambiental válida', () => {",
                  "    const labels = ['A+++','A++','A+','A','B','C','D','E','F'];",
                  "    const label = pm.response.json().environmental_label?.label?.label;",
                  "    pm.expect(labels).to.include(label);",
                  "});",
                  "pm.test('processor_used válido', () => {",
                  "    pm.expect(['cpu','gpu','npu']).to.include(pm.response.json().metadata.device_processor);",
                  "});",
                  "pm.collectionVariables.set('gpt4_co2', pm.response.json().emissions_gCO2.total);"
                ]
              }
            }
          ]
        },
