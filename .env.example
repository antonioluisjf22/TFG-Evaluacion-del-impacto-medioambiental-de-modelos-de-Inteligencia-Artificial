# Copia este archivo como .env y rellena los valores antes de ejecutar la app.
# El .env nunca se sube al repositorio (está en .gitignore).

# Clave secreta de Flask para firmar cookies de sesión.
# Genera un valor seguro con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=cambia-esto-por-un-valor-seguro

# Token de autenticación para la API de Electricity Maps.
# Regístrate en https://api-portal.electricitymaps.com para obtenerlo.
# Si no se configura, la app funciona en modo offline (datos históricos del CSV).
ELECTRICITY_MAPS_API_KEY=tu-api-key-aqui
